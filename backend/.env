# ===========================================
# ENVIRONMENT VARIABLES - Woli Delivery API
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database - MySQL (WAMP)
DATABASE_URL="mysql://root:@localhost:3306/db_resto"
# Redis (optionnel - peut être commenté si non utilisé)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=woli-delivery-secret-key-2024-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# CORS - Specific origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
