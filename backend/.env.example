# ===========================================
# ENVIRONMENT VARIABLES - Woli Delivery API
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database - MySQL
DATABASE_URL="mysql://root:password@localhost:3306/woli_delivery?schema=public&connection_limit=10"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
